{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|favicon.ico|vite.svg).*)",
      "destination": "/index.html"
    }
  ]
}
